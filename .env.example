# ---------------------------------------------------------------------------
# Book Studio AI — environment variables
# Copy to `.env.local` and fill in when you wire up real services.
# The MVP runs fully WITHOUT any of these (client-side persistence + placeholder AI).
# ---------------------------------------------------------------------------

# Database (Railway Postgres) — used by Drizzle once you move off client storage
DATABASE_URL=

# Clerk auth (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# AI provider — wire into src/lib/ai/* when ready (OpenAI or Anthropic)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Stripe (placeholder only in MVP)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
